# Copy this file to .env only for an explicitly authorized local or operator task.
# Offline validation does not need an environment file.
# Never put real credentials, tokens, private paths, or account identifiers here.
# Empty credential and resource fields are intentional: dependent operations must
# fail closed until a human supplies approved, least-privilege values privately.

# Snowflake warehouse. Use a dedicated NRFI role with only the documented object
# permissions. Never use ACCOUNTADMIN, SECURITYADMIN, or SYSADMIN.
SNOWFLAKE_ACCOUNT=
SNOWFLAKE_USER=
SNOWFLAKE_PASSWORD=
SNOWFLAKE_DATABASE=
SNOWFLAKE_SCHEMA=
SNOWFLAKE_WAREHOUSE=
SNOWFLAKE_ROLE=

# Exact OpticOdds first-inning total 0.5 market configuration. Leave blank
# unless an existing, approved account is available; do not create a subscription.
OPTIC_API_KEY=
OPTIC_FI_TOTAL_MARKET_ID=
OPTIC_BASE_URL=https://api.opticodds.com/api/v3
NRFI_SPORTSBOOKS=DraftKings,FanDuel,BetMGM,Caesars,Pinnacle
ODDS_MAX_AGE_SECONDS=600
MIN_BOOKS_FOR_MARKET=2
FEATURE_COVERAGE_MIN=0.85
HIGH_TIER_COVERAGE_MIN=0.95

# Serving security. A blank bearer token disables protected POST routes.
API_BEARER_TOKEN=
ALLOWED_ORIGINS=http://localhost:3000
API_HOST=127.0.0.1
API_PORT=8000

# Optional observability and alerting. Blank GitHub values keep alerts log-only.
SENTRY_DSN=
ENV=development
GH_TOKEN=
GITHUB_REPO=
OWM_API_KEY=

# Optional local staging only; not consumed by the normalized training pipeline.
DATABASE_URL=sqlite:///data/nrfi.db
